# Database (PostgreSQL — Neon for production, local PG for development)
DATABASE_URL=postgresql://user:***@host/database?sslmode=require

# LLM API Key (DeepSeek V4 Flash via OpenCode Go)
OPENCODE_GO_API_KEY=your-opencode-go-api-key

# OpenRouter Fallback (for owl-alpha as last-resort evaluator fallback)
OPENROUTER_API_KEY=your-openrouter-api-key

# Rate Limiting (max analyses per IP per day)
RATE_LIMIT_PER_DAY=10

# Application
NEXT_PUBLIC_APP_URL=https://ganyiq.vercel.app

# V2 Multi-Generator Shadow Deployment (Phase 3B)
# V2_MULTI_GENERATOR_SHADOW=true  → Run V2 Fusion silently alongside V1
# V2_MULTI_GENERATOR_SHADOW=false → V1 only (default)
# V2_MULTI_GENERATOR_OUTPUT=false → Keep V1 as user-visible output
V2_MULTI_GENERATOR_SHADOW=false
V2_MULTI_GENERATOR_OUTPUT=false

# V2 Canary Rollout (Phase 3C)
# V2_CANARY_ENABLED=true      → Enable canary routing
# V2_CANARY_PERCENT=1         → % of traffic to route to V2 (1, 5, 10, 25, 50, 100)
V2_CANARY_ENABLED=false
V2_CANARY_PERCENT=0

# === TRANSCRIPT PROVIDERS ===

# VibeVoice vLLM Server (for speaker diarization / multi-speaker content)
# Runs on PC-GANY with GPU. Default: http://localhost:8000
VIBEVOICE_API_URL=http://localhost:8000
VIBEVOICE_API_KEY=

# FasterWhisper (local CPU fallback)
# Model: tiny, base, small (default), medium, large-v3
FASTER_WHISPER_MODEL=small
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE=int8

# Deepgram (primary STT — already configured in .env.local)
DEEPGRAM_API_KEY=your-deepgram-api-key
