# Database (PostgreSQL — Neon for production, local PG for development)
DATABASE_URL=postgresql://user:***@host/database?sslmode=require

# LLM API Key (DeepSeek V4 Flash via OpenCode Go)
OPENCODE_GO_API_KEY=your-opencode-go-api-key

# Rate Limiting (max analyses per IP per day)
RATE_LIMIT_PER_DAY=10

# Application
NEXT_PUBLIC_APP_URL=https://ganyiq.vercel.app
